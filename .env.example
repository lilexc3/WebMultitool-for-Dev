# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# GitLab
GITLAB_URL=http://your-gitlab-url
GITLAB_TOKEN=your_gitlab_token_here
GITLAB_PROJECT_ID=1

# Prometheus
PROMETHEUS_URL=http://localhost:9090

# Database
POSTGRES_DB=devops_webapp
POSTGRES_USER=devops
POSTGRES_PASSWORD=devops_password
DATABASE_URL=postgresql://devops:devops_password@localhost:5432/devops_webapp

# Security / TLS
# false = проверять сертификаты (рекомендуется)
# true  = разрешить self-signed (не рекомендуется для прод)
ALLOW_INSECURE_TLS=false
# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# GitLab
GITLAB_URL=http://your-gitlab-url
GITLAB_TOKEN=your_gitlab_token_here
GITLAB_PROJECT_ID=1

# Prometheus (только если API запускаете на хосте: uvicorn без Docker)
# В docker compose для сервиса api URL к Prometheus зашит в docker-compose.yml → http://prometheus:9090
PROMETHEUS_URL=http://localhost:9090

# Database
POSTGRES_DB=devops_webapp
POSTGRES_USER=devops
POSTGRES_PASSWORD=devops_password
# Для Docker: postgresql://devops:devops_password@postgres:5432/devops_webapp
# Для локального запуска: postgresql://devops:devops_password@localhost:5432/devops_webapp
DATABASE_URL=postgresql://devops:devops_password@localhost:5432/devops_webapp

# Security / TLS
# false = проверять сертификаты (рекомендуется)
# true  = разрешить self-signed (не рекомендуется для прод)
ALLOW_INSECURE_TLS=false

# Публичный URL API (для формирования команды установки агента)
# Для локального теста: http://localhost:8000
# Для продакшена: https://your-domain.com
API_PUBLIC_URL=http://localhost:8000
# Токен агента (получить из API при создании ноды)
AGENT_TOKEN=your_agent_token_here

# URL WebSocket API
# Для локального теста: ws://localhost:8000/ws/agent
# Для продакшена: wss://your-domain.com/ws/agent
API_URL=ws://localhost:8000/ws/agent

# Разрешить self-signed сертификаты (только для тестов!)
# false = проверять сертификаты (рекомендуется для продакшена)
# true  = разрешить непроверенные сертификаты
ALLOW_INSECURE_TLS=false
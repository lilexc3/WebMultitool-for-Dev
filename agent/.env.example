# Токен агента (получить из API при создании сайта)
AGENT_TOKEN=your_agent_token_here

# URL API (локальный или публичный)
# Для локального теста: ws://localhost:8000/ws/agent
# Для продакшена: wss://your-domain.com/ws/agent
API_URL=ws://localhost:8000/ws/agent

# Путь к сайту на сервере
SITE_PATH=/var/www/site

# URL репозитория с кодом сайта
REPO_URL=https://github.com/your-username/your-repo.git
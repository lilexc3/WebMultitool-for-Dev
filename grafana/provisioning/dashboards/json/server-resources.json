{
  "uid": "server-resources",
  "title": "Server Resources",
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "CPU",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "CPU Usage",
      "gridPos": {"x": 0, "y": 1, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\", job=\"node\"}[5m]))*100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU Usage History",
      "gridPos": {"x": 6, "y": 1, "w": 18, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\", job=\"node\"}[5m]))*100)",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100}
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Memory",
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Memory Usage",
      "gridPos": {"x": 0, "y": 6, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "(1 - node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"}) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Memory Usage History",
      "gridPos": {"x": 6, "y": 6, "w": 18, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "(1 - node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"}) * 100",
          "legendFormat": "RAM",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100}
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Disk",
      "gridPos": {"x": 0, "y": 10, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Disk Usage",
      "gridPos": {"x": 0, "y": 11, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "100 - (node_filesystem_avail_bytes{job=\"node\", mountpoint=\"/var/lib/docker\"} / node_filesystem_size_bytes{job=\"node\", mountpoint=\"/var/lib/docker\"} * 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Disk Usage History",
      "gridPos": {"x": 6, "y": 11, "w": 18, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "100 - (node_filesystem_avail_bytes{job=\"node\", mountpoint=\"/var/lib/docker\"} / node_filesystem_size_bytes{job=\"node\", mountpoint=\"/var/lib/docker\"} * 100)",
          "legendFormat": "Disk",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100}
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "System",
      "gridPos": {"x": 0, "y": 15, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Load Average",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 5},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "node_load1{job=\"node\"}",
          "legendFormat": "1m",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "node_load5{job=\"node\"}",
          "legendFormat": "5m",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "node_load15{job=\"node\"}",
          "legendFormat": "15m",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "min": 0}
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Network Traffic",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 5},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "rate(node_network_receive_bytes_total{job=\"node\"}[5m])",
          "legendFormat": "In",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "rate(node_network_transmit_bytes_total{job=\"node\"}[5m])",
          "legendFormat": "Out",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "Bps"}
      }
    }
  ]
}

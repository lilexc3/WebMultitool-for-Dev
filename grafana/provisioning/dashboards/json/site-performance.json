{
  "uid": "site-performance",
  "title": "Site Performance",
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "site_url",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "query": "label_values(probe_success{job=\"blackbox-http\"}, instance)",
        "multi": false,
        "includeAll": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Status",
      "gridPos": {"x": 0, "y": 1, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "probe_success{instance=\"$site_url\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "value": "1", "text": "🟢 ONLINE"},
            {"type": "value", "value": "0", "text": "🔴 OFFLINE"}
          ],
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Uptime (24h)",
      "gridPos": {"x": 6, "y": 1, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "avg_over_time(probe_success{instance=\"$site_url\"}[24h]) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 99},
              {"color": "green", "value": 99.9}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Response Time",
      "gridPos": {"x": 12, "y": 1, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "probe_duration_seconds{instance=\"$site_url\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "SSL Cert",
      "gridPos": {"x": 18, "y": 1, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "(probe_ssl_earliest_cert_expiry{instance=\"$site_url\"} - time()) / 86400",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "decimals": 0,
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 30},
              {"color": "green", "value": 60}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}}
    },
    {
      "id": 10,
      "type": "row",
      "title": "Response Time & Status",
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Response Time",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 6},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "probe_duration_seconds{instance=\"$site_url\"}",
          "legendFormat": "Response Time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "min": 0}
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP Status Codes",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 6},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "probe_http_status_code{instance=\"$site_url\"}",
          "legendFormat": "HTTP {{value}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "min": 0}
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Uptime",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Uptime (7 days)",
      "gridPos": {"x": 0, "y": 13, "w": 8, "h": 3},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "avg_over_time(probe_success{instance=\"$site_url\"}[168h]) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 99},
              {"color": "green", "value": 99.9}
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Uptime (30 days)",
      "gridPos": {"x": 8, "y": 13, "w": 8, "h": 3},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "avg_over_time(probe_success{instance=\"$site_url\"}[720h]) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 99},
              {"color": "green", "value": 99.9}
            ]
          }
        }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Uptime Trend (7 days)",
      "gridPos": {"x": 16, "y": 13, "w": 8, "h": 3},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "avg_over_time(probe_success{instance=\"$site_url\"}[1h]) * 100",
          "legendFormat": "Uptime %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100}
      }
    }
  ]
}
